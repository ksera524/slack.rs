# Slack設定
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_API_BASE_URL=https://slack.com/api

# S3互換設定 (RustFS / MinIO など)
RUSTFS_S3_ACCESS_KEY_ID=your-access-key-id
RUSTFS_S3_SECRET_ACCESS_KEY=your-secret-access-key
RUSTFS_S3_REGION=us-east-1
RUSTFS_S3_ENDPOINT=http://rustfs.example.local:9000
RUSTFS_S3_USE_PATH_STYLE=true
# RUSTFS_S3_SESSION_TOKEN=

# ログ設定
# ログレベル (trace, debug, info, warn, error)
RUST_LOG=info

# ログ形式: JSONL (JSON Lines) 形式固定
# 1行に1つのJSONオブジェクトを出力し、ログ解析ツールやストリーミング処理に最適化

# ログオプション
NO_COLOR=false          # カラー出力を無効化する場合はtrue
LOG_TARGET=false        # モジュール名を表示する場合はtrue
LOG_THREAD=false        # スレッド情報を表示する場合はtrue
LOG_LINE=false          # 行番号を表示する場合はtrue

# 特定モジュールのログレベル設定例
# RUST_LOG=api_hub=debug,tower_http=trace,info

# 本番環境向け設定例
# RUST_LOG=info,api_hub::service=debug
# LOG_TARGET=true
# LOG_LINE=false

# ログ解析ツール向け設定例
# RUST_LOG=info
# LOG_TARGET=true
# LOG_THREAD=true
